{
  "name": "chord-supporting-helper-application",
  "version": "0.9.0",
  "description": "ChordCanvas is a browser-based music idea tool designed to help musicians find the next part of a chord progression without handing the whole creative process over to AI.",
  "main": "index.js",
  "scripts": {
    "preview:chrome": "node open-browser.js chromium",
    "preview:firefox": "node open-browser.js firefox",
    "preview:safari": "node open-browser.js webkit",
    "release:minor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-merge-cleanup.ps1",
    "release:minor:delete": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-merge-cleanup.ps1 -DeleteRepoAfterSuccess",
    "test:syntax": "node tests/syntax-check.cjs",
    "test:e2e": "playwright test",
    "test": "npm run test:syntax && npm run test:e2e",
    "branches:prune": "git fetch --prune",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beccapowellstuff/Chord-Supporting-Helper-Application.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/beccapowellstuff/Chord-Supporting-Helper-Application/issues"
  },
  "homepage": "https://github.com/beccapowellstuff/Chord-Supporting-Helper-Application#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  }
}
